{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Elasticsearch"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AuditDb": "SET_IN_ENV"
  },
  "Jwt": {
    "Secret": "SET_IN_ENV",
    "Issuer": "AuditManagement.System",
    "Audience": "AuditManagement.Client",
    "ExpiryMinutes": 60
  },
  "ServiceUrls": {
    "ObservationService": "SET_IN_ENV",
    "ReportingService": "SET_IN_ENV",
    "NotificationService": "SET_IN_ENV"
  },
  "Elasticsearch": {
    "Uri": "SET_IN_ENV",
    "Username": "SET_IN_ENV",
    "Password": "SET_IN_ENV"
  }
}
